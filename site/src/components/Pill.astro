---
// Pill.astro - small rounded status/label chip
//
// Usage:
//   <Pill variant="success" title="Added in patch 15.17">
//     <CirclePlusIcon slot="icon" size={12} strokeWidth={2.5} />
//     15.17
//   </Pill>

interface Props {
  variant?: "neutral" | "accent" | "success" | "warning" | "danger";
  title?: string;
}

const { variant = "neutral", title } = Astro.props;
---

<span class:list={["pill", `pill-${variant}`]} title={title}>
  <slot name="icon" />
  <slot />
</span>

<style>
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.2rem 0.5rem;
    border-radius: 0.4rem;
    border: 1px solid transparent;
    font-size: 0.75rem;
    font-weight: 500;
    line-height: 1.2;
    white-space: nowrap;
  }

  /* Slotted icons come from the parent component, so scope with :global */
  .pill :global(svg) {
    flex-shrink: 0;
    opacity: 0.8;
  }

  .pill-neutral {
    color: var(--sl-color-gray-3, #6b7280);
    background: var(--sl-color-gray-6, #f9fafb);
    border-color: var(--sl-color-gray-5, #e5e7eb);
  }

  .pill-accent {
    color: var(--sl-color-accent-high, #3730a3);
    background: color-mix(in srgb, var(--sl-color-accent, #4f46e5) 12%, transparent);
    border-color: color-mix(in srgb, var(--sl-color-accent, #4f46e5) 35%, transparent);
  }

  .pill-success {
    color: var(--sl-color-green-high, #15803d);
    background: color-mix(in srgb, var(--sl-color-green, #22c55e) 12%, transparent);
    border-color: color-mix(in srgb, var(--sl-color-green, #22c55e) 35%, transparent);
  }

  .pill-warning {
    color: var(--sl-color-orange-high, #c2410c);
    background: color-mix(in srgb, var(--sl-color-orange, #f97316) 12%, transparent);
    border-color: color-mix(in srgb, var(--sl-color-orange, #f97316) 35%, transparent);
  }

  .pill-danger {
    color: var(--sl-color-red-high, #b91c1c);
    background: color-mix(in srgb, var(--sl-color-red, #ef4444) 12%, transparent);
    border-color: color-mix(in srgb, var(--sl-color-red, #ef4444) 35%, transparent);
  }
</style>
