---
import AddDocumentationButton from "./AddDocumentationButton.astro";
import FileTextIcon from "./icons/FileTextIcon.astro";
import InfoIcon from "./icons/InfoIcon.astro";
import { renderMarkdown, renderMarkdownSnippet } from "../utils/markdown";
import type { PropertyDocumentation } from "../types";

interface Props {
  docs?: PropertyDocumentation | null;
  name: string;
  propertyName: string;
  docExists: boolean;
}

const { docs, name, propertyName, docExists } = Astro.props;
---

<div class="property-docs">
  <div class="docs-header" data-pagefind-ignore>
    <label class="docs-label">
      <FileTextIcon />
      Documentation
    </label>
    <AddDocumentationButton
      name={name}
      propertyName={propertyName}
      docExists={docExists}
      documented={!!docs?.description}
    />
  </div>
  <div class="docs-content">
    {
      docs?.description ? (
        <div class="docs-text">
          <div
            class="docs-description"
            set:html={renderMarkdown(docs.description)}
          />
          {docs.examples && docs.examples.length > 0 && (
            <div class="docs-section">
              <strong>Examples:</strong>
              <ul>
                {docs.examples.map((ex: string) => (
                  <li set:html={renderMarkdownSnippet(ex)} />
                ))}
              </ul>
            </div>
          )}
        </div>
      ) : (
        <p class="docs-placeholder" data-pagefind-ignore>
          No documentation available yet. Click "Add documentation" to
          contribute!
        </p>
      )
    }
  </div>
  {
    docs?.notes && docs.notes.length > 0 && (
      <aside class="docs-notes docs-text">
        <div class="notes-label" data-pagefind-ignore>
          <InfoIcon />
          Notes
        </div>
        <ul class="notes-list">
          {docs.notes.map((note: string) => (
            <li set:html={renderMarkdownSnippet(note)} />
          ))}
        </ul>
      </aside>
    )
  }
</div>

<style>
  .property-docs {
    margin-top: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--sl-color-gray-6, #f3f4f6);
  }

  .docs-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.375rem;
  }

  .docs-label {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--sl-color-gray-3, #6b7280);
    margin-bottom: 0.375rem;
  }

  .docs-content {
    /* Darker than the card (bg-nav is gray-6 in dark mode) so the
       documentation reads as a recessed panel inside the card */
    background: var(--sl-color-bg, #f9fafb);
    border: 1px solid var(--sl-color-gray-5, #e5e7eb);
    border-radius: 0.375rem;
    padding: 0.5rem 0.75rem;
  }

  .docs-notes {
    margin-top: 0.5rem;
    padding: 0.5rem 0.75rem;
    background: var(--sl-color-accent-low, #e0e7ff);
    border-left: 3px solid var(--sl-color-accent, #4f46e5);
    border-radius: 0.375rem;
  }

  .notes-label {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--sl-color-accent-high, #3730a3);
    margin-bottom: 0.25rem;
  }

  /* Icons come from child components, so scope with :global */
  .notes-label :global(svg) {
    flex-shrink: 0;
  }

  .notes-list {
    margin: 0;
    padding-left: 1.25rem;
  }

  .docs-notes li {
    margin: 0.125rem 0;
  }

  .docs-placeholder {
    margin: 0;
    color: var(--sl-color-gray-3, #9ca3af);
    font-size: 0.813rem;
    font-style: italic;
  }

  .docs-text {
    font-size: 0.813rem;
    line-height: 1.5;
    color: var(--sl-color-white, #1f2937);
    overflow-wrap: break-word;
  }

  .docs-description {
    margin: 0 0 0.5rem 0;
  }

  .docs-description:last-child {
    margin-bottom: 0;
  }

  /* Markdown content (set:html, so :global is required) */
  .docs-text :global(p) {
    margin: 0 0 0.5rem 0;
  }

  .docs-text :global(p:last-child) {
    margin-bottom: 0;
  }

  .docs-text :global(a) {
    color: var(--sl-color-accent, #4f46e5);
    text-decoration: none;
    font-weight: 500;
  }

  .docs-text :global(a:hover) {
    text-decoration: underline;
  }

  .docs-text :global(code) {
    font-size: 0.9em;
    background: var(--sl-color-bg-inline-code, #f3f4f6);
    border: 1px solid var(--sl-color-gray-5, #e5e7eb);
    border-radius: 0.25rem;
    padding: 0.0625rem 0.3125rem;
  }

  .docs-text :global(pre) {
    margin: 0 0 0.5rem 0;
    padding: 0.5rem 0.75rem;
    background: var(--sl-color-gray-6, #f9fafb);
    border: 1px solid var(--sl-color-gray-5, #e5e7eb);
    border-radius: 0.375rem;
    overflow-x: auto;
    font-size: 0.75rem;
    line-height: 1.5;
  }

  .docs-text :global(pre code) {
    background: transparent;
    border: none;
    padding: 0;
  }

  .docs-text :global(ul),
  .docs-text :global(ol) {
    margin: 0 0 0.5rem 0;
    padding-left: 1.25rem;
  }

  .docs-text :global(ul:last-child),
  .docs-text :global(ol:last-child) {
    margin-bottom: 0;
  }

  .docs-text :global(.md-table-scroll) {
    max-width: 100%;
    overflow-x: auto;
    margin: 0 0 0.5rem 0;
  }

  .docs-text :global(.md-table-scroll:last-child) {
    margin-bottom: 0;
  }

  .docs-text :global(table) {
    border-collapse: collapse;
    margin: 0;
    font-size: 0.75rem;
  }

  .docs-text :global(th),
  .docs-text :global(td) {
    border: 1px solid var(--sl-color-gray-5, #e5e7eb);
    padding: 0.25rem 0.5rem;
    text-align: left;
  }

  .docs-text :global(th) {
    background: var(--sl-color-gray-6, #f9fafb);
    font-weight: 600;
  }

  /* Code tokens in table cells must not break mid-token; the wrapper scrolls instead */
  .docs-text :global(table code) {
    white-space: nowrap;
  }

  .docs-text :global(blockquote) {
    margin: 0 0 0.5rem 0;
    padding: 0.125rem 0 0.125rem 0.625rem;
    border-left: 3px solid var(--sl-color-gray-5, #e5e7eb);
    color: var(--sl-color-gray-2, #6b7280);
  }

  .docs-text :global(h1),
  .docs-text :global(h2),
  .docs-text :global(h3),
  .docs-text :global(h4) {
    font-size: 0.875rem;
    font-weight: 600;
    margin: 0.625rem 0 0.375rem 0;
    color: var(--sl-color-white, #111827);
  }

  .docs-section {
    margin-top: 0.5rem;
  }

  .docs-section strong {
    display: block;
    margin-bottom: 0.25rem;
    color: var(--sl-color-white, #111827);
  }

  .docs-section ul {
    margin: 0;
    padding-left: 1.25rem;
  }

  .docs-section li {
    margin: 0.125rem 0;
  }
</style>
