---
import PropertyCard from "./PropertyCard.astro";
import PropertyScrollHandler from "./PropertyScrollHandler.astro";
import type { Property } from "../types";

interface Props {
  properties: Property[];
  classIndex: Record<string, string>;
  name: string;
  docExists: boolean;
}

const { properties, classIndex, name, docExists } = Astro.props;
---

<!-- Search indexing: only each property's name and its documentation text are
     indexed. Type links (other class names), default values, and repeated UI
     chrome are excluded so pages don't match unrelated searches. -->
<section class="properties-section not-content">
  <h2 class="section-title" data-pagefind-ignore>Properties</h2>
  <div class="properties-grid">
    {
      properties.map((p) => (
        <PropertyCard
          property={p}
          classIndex={classIndex}
          name={name}
          docExists={docExists}
        />
      ))
    }
  </div>
</section>

<style>
  .properties-section {
    margin-top: 0;
  }

  .section-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0 0 0.75rem 0;
    color: var(--sl-color-white, #1f2937);
  }

  .properties-grid {
    display: grid;
    /* minmax(0, 1fr) lets cards shrink below their content's intrinsic width,
       so wide markdown tables scroll inside the card instead of stretching it */
    grid-template-columns: minmax(0, 1fr);
    gap: 0.75rem;
  }
</style>

<PropertyScrollHandler properties={properties} />
