---
interface DescendantNode {
  name: string;
  children: DescendantNode[];
}

interface Props {
  currentClass: string;
  ancestorLevels: string[][];
  descendantTree: DescendantNode[];
  classIndex: Record<string, string>;
}

const {
  currentClass,
  ancestorLevels = [],
  descendantTree = [],
  classIndex,
} = Astro.props;

// Nothing to show for classes with no inheritance relationships
if (ancestorLevels.length === 0 && descendantTree.length === 0) {
  return null;
}

function subtreeSize(node: DescendantNode): number {
  return 1 + node.children.reduce((n, c) => n + subtreeSize(c), 0);
}

// Class chip with an optional descendant count baked into the chip itself
function nodeChip(name: string, count?: number): string {
  const countHtml =
    count !== undefined ? `<span class="chip-count">${count}</span>` : "";
  const href = classIndex[name];
  if (href) {
    return `<a href="${href}" class="chip chip-link">${name}${countHtml}</a>`;
  }
  return `<span class="chip">${name}${countHtml}</span>`;
}

const descendantCount = descendantTree.reduce((n, c) => n + subtreeSize(c), 0);
const ancestorCount = ancestorLevels.reduce((n, l) => n + l.length, 0);

// Small trees render fully expanded; big ones keep the current class's
// direct children visible and collapse deeper branches behind <details>
const expandAll = descendantCount <= 40;

function nodeHtml(node: DescendantNode): string {
  if (node.children.length === 0) {
    return `<li><span class="node-row"><span class="twisty-spacer"></span>${nodeChip(node.name)}</span></li>`;
  }
  const kids = node.children.map(nodeHtml).join("");
  return (
    `<li><details${expandAll ? " open" : ""}>` +
    `<summary class="node-row">${nodeChip(node.name, subtreeSize(node) - 1)}</summary>` +
    `<ul>${kids}</ul>` +
    `</details></li>`
  );
}

// Current class node: never collapsible, its children always visible
const childrenHtml = descendantTree.map(nodeHtml).join("");
let treeHtml =
  `<li><span class="node-row"><span class="twisty-spacer"></span>` +
  `<span class="current-class">${currentClass}<span class="badge">current</span></span></span>` +
  (childrenHtml ? `<ul>${childrenHtml}</ul>` : "") +
  `</li>`;

// Wrap ancestor levels around it, deepest ancestor outermost. A level with
// several classes (multiple inheritance) renders its chips side by side.
for (const level of ancestorLevels) {
  const chips = level
    .map((n) => nodeChip(n))
    .join(`<span class="level-sep">&amp;</span>`);
  treeHtml =
    `<li><span class="node-row"><span class="twisty-spacer"></span>${chips}</span>` +
    `<ul>${treeHtml}</ul></li>`;
}
treeHtml = `<ul class="tree-root">${treeHtml}</ul>`;

const countsLabel = [
  ancestorCount > 0 ? `${ancestorCount} ancestor${ancestorCount === 1 ? "" : "s"}` : null,
  descendantCount > 0 ? `${descendantCount} descendant${descendantCount === 1 ? "" : "s"}` : null,
]
  .filter(Boolean)
  .join(" · ");
---

<!-- data-pagefind-ignore: the tree names dozens of *other* classes; indexing it
     would make every class match searches for its ancestors/descendants -->
<div class="inheritance-section not-content" data-pagefind-ignore>
  <h2>
    Inheritance
    {countsLabel && <span class="counts">{countsLabel}</span>}
  </h2>

  <div class="tree" set:html={treeHtml} />
</div>

<style>
  .inheritance-section {
    margin-bottom: 2rem;
  }

  .inheritance-section h2 {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    margin-top: 0;
    margin-bottom: 0.75rem;
    font-size: 1.25rem;
    font-weight: 600;
  }

  .counts {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--sl-color-gray-3, #6b7280);
  }

  .tree {
    background: var(--sl-color-bg);
    padding: 0.625rem 0.875rem;
    border-radius: 0.5rem;
    border: 1px solid var(--sl-color-gray-5);
    font-size: 0.8125rem;
    overflow-x: auto;
  }

  .tree :global(ul) {
    list-style: none;
    margin: 0;
    padding: 0 0 0 1.25rem;
  }

  .tree :global(ul.tree-root) {
    padding-left: 0;
  }

  .tree :global(li) {
    position: relative;
    padding: 0;
  }

  /* Connector lines (skipped on the root row) */
  .tree :global(ul:not(.tree-root) > li)::before {
    content: "";
    position: absolute;
    left: -0.8rem;
    top: 0.75rem;
    width: 0.6rem;
    height: 1px;
    background: var(--sl-color-gray-5, #e5e7eb);
  }

  .tree :global(ul:not(.tree-root) > li)::after {
    content: "";
    position: absolute;
    left: -0.8rem;
    top: 0;
    bottom: 0;
    width: 1px;
    background: var(--sl-color-gray-5, #e5e7eb);
  }

  .tree :global(ul:not(.tree-root) > li:last-child)::after {
    bottom: auto;
    height: 0.75rem;
  }

  /* Every row is exactly one line high so the tree reads as a grid */
  .tree :global(.node-row) {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    height: 1.5rem;
  }

  .tree :global(.twisty-spacer) {
    display: inline-block;
    width: 0.9rem;
    flex-shrink: 0;
  }

  /* Collapsible branches */
  .tree :global(summary.node-row) {
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .tree :global(summary.node-row)::-webkit-details-marker {
    display: none;
  }

  .tree :global(summary.node-row)::before {
    content: "\25B8"; /* ▸ */
    display: inline-flex;
    justify-content: center;
    width: 0.9rem;
    flex-shrink: 0;
    color: var(--sl-color-gray-3, #6b7280);
    font-size: 0.7rem;
    transition: transform 0.15s ease;
  }

  .tree :global(details[open] > summary.node-row)::before {
    transform: rotate(90deg);
  }

  .tree :global(.chip-count) {
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--sl-color-gray-3, #6b7280);
    border-left: 1px solid var(--sl-color-gray-5, #e5e7eb);
    padding-left: 0.35rem;
    line-height: 1.2;
  }

  .tree :global(.level-sep) {
    color: var(--sl-color-gray-3, #6b7280);
    font-size: 0.7rem;
    user-select: none;
  }

  /* Same metrics as .chip so the row height stays constant */
  .tree :global(.current-class) {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-mono, ui-monospace, Consolas, monospace);
    font-weight: 700;
    font-size: 0.75rem;
    line-height: 1.4;
    color: var(--sl-color-accent, #4f46e5);
    padding: 0.1rem 0.45rem;
    background: var(--sl-color-accent-low, #e0e7ff);
    border-radius: 0.375rem;
    border: 1px solid var(--sl-color-accent, #4f46e5);
    white-space: nowrap;
  }

  .tree :global(.badge) {
    font-size: 0.6rem;
    font-weight: 600;
    padding: 0 0.3rem;
    line-height: 1.5;
    background: var(--sl-color-accent, #4f46e5);
    color: white;
    border-radius: 0.25rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Class reference chips */
  .tree :global(.chip) {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.1rem 0.45rem;
    border-radius: 0.375rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--sl-color-gray-5);
    font-family: var(--font-mono, ui-monospace, Consolas, monospace);
    font-size: 0.75rem;
    line-height: 1.4;
    transition: all 0.15s ease;
    white-space: nowrap;
  }

  .tree :global(.chip-link) {
    color: var(--sl-color-text);
    text-decoration: none;
  }

  .tree :global(.chip-link:hover) {
    background: rgba(79, 70, 229, 0.15);
    border-color: var(--sl-color-accent);
    color: var(--sl-color-accent);
  }
</style>
