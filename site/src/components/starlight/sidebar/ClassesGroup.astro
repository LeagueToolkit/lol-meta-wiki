---
/**
 * Client-rendered "Classes" sidebar group.
 *
 * The ~5,300 class links are deliberately absent from the static sidebar
 * (see astro.config.mjs): baking them into every page made each HTML file
 * ~850KB and dominated build time. Instead, the group is built in the browser
 * from /db/classSidebar.json (grouped at generate time by
 * scripts/generate-db.ts) and cached per tab:
 *
 * - First page view in a tab: the is:inline script injects a skeleton
 *   placeholder, then the module script fetches the JSON, builds the group
 *   DOM, swaps it in for the skeleton, and caches its HTML in sessionStorage.
 * - Later navigations: the is:inline script re-injects the cached HTML
 *   synchronously during HTML parsing, so the group appears without any
 *   flash or delay.
 *
 * Must be rendered *after* the default sidebar - both scripts attach to the
 * server-rendered sidebar DOM.
 */
---

<script is:inline>
  // Runs synchronously during HTML parsing. Fast path: restore the cached
  // group. No cache yet (first view in this tab): inject a skeleton
  // placeholder that the module script below replaces once the group is
  // built. Duplicates small bits of the module script (storage keys,
  // current-page marking, branch expansion, scroll centering) because inline
  // scripts can't share code with it - keep in sync.
  (() => {
    try {
      const topLevel = document.querySelector("#starlight__sidebar ul.top-level");
      if (!topLevel || topLevel.querySelector("[data-wiki-classes-group]"))
        return;

      const cached = sessionStorage.getItem("wiki-classes-group-html-v2");
      if (!cached) {
        injectSkeleton(topLevel);
        return;
      }
      topLevel.insertAdjacentHTML("beforeend", cached);

      const group = topLevel.querySelector("[data-wiki-classes-group]");
      const details = group.querySelector("details");
      const path = location.pathname.replace(/\/$/, "");
      const currentLink =
        group.querySelector(`a[href="${path}/"]`) ||
        group.querySelector(`a[href="${path}"]`);

      if (currentLink) {
        currentLink.setAttribute("aria-current", "page");
        // Expand the subgroup(s) the current class sits in
        for (let el = currentLink; el && el !== group; el = el.parentElement) {
          if (el.tagName === "DETAILS") el.open = true;
        }
      }

      // Open when viewing a class page; otherwise restore the last user choice
      details.open =
        !!currentLink ||
        sessionStorage.getItem("wiki-classes-group-open") !== "false";
      details.addEventListener("toggle", () => {
        try {
          sessionStorage.setItem(
            "wiki-classes-group-open",
            String(details.open),
          );
        } catch {}
      });

      // Center the current class in the sidebar scroller. This runs after
      // Starlight's own scroll restore (its inline script sits earlier in
      // the sidebar), so this position wins on class pages.
      const scroller = document.getElementById("starlight__sidebar");
      if (currentLink && scroller) {
        scroller.scrollTop =
          currentLink.getBoundingClientRect().top -
          scroller.getBoundingClientRect().top +
          scroller.scrollTop -
          scroller.clientHeight / 2;
      }

      // Placeholder "Classes" group with shimmer rows, so the sidebar shows
      // the group is coming (and doesn't jump) while the module script builds
      // the real one. Clones an existing group so it inherits Starlight's
      // scoped styles, same trick as the builder.
      function injectSkeleton(topLevel) {
        const template = topLevel
          .querySelector(":scope > li > details")
          ?.closest("li");
        if (!template) return;
        const li = template.cloneNode(true);
        li.setAttribute("data-wiki-classes-skeleton", "");
        li.querySelectorAll("sl-sidebar-restore").forEach((el) => el.remove());
        li.querySelectorAll("[aria-current]").forEach((el) =>
          el.removeAttribute("aria-current"),
        );
        const label = li.querySelector("summary .group-label .large");
        if (label) label.textContent = "Classes";
        const details = li.querySelector("details");
        // Clear the clone's server-rendered open attribute, then apply the
        // user's last choice (expanded by default)
        details.removeAttribute("open");
        if (sessionStorage.getItem("wiki-classes-group-open") !== "false") {
          details.open = true;
        }
        details.querySelector("ul").innerHTML = [64, 48, 71, 55, 38, 66, 44, 58]
          .map(
            (w) =>
              `<li class="wiki-classes-skeleton-row" style="width:${w}%"></li>`,
          )
          .join("");
        topLevel.appendChild(li);
      }
    } catch {}
  })();
</script>

<style is:global>
  /* Rows of the skeleton "Classes" group shown while the real one is built on
     the first page view in a tab. is:global because the rows are created by
     the inline script above, so Astro's scoped-style class never reaches
     them. Same translucent-overlay trick as the sidebar hover highlight in
     custom.css - a fixed gray would vanish against the dark-mode sidebar. */
  .wiki-classes-skeleton-row {
    height: 1.0625rem;
    margin: 0.6rem 0.5rem;
    border-radius: 0.25rem;
    background-color: color-mix(in srgb, var(--sl-color-white) 10%, transparent);
    animation: wiki-classes-skeleton-pulse 1.2s ease-in-out infinite;
  }

  @keyframes wiki-classes-skeleton-pulse {
    50% {
      opacity: 0.4;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .wiki-classes-skeleton-row {
      animation: none;
    }
  }
</style>

<script>
  /**
   * First-time build of the group (the is:inline script above is the fast
   * path). Clones existing server-rendered sidebar DOM as templates so the
   * new elements inherit Starlight's scoped style classes.
   */
  import type { ClassSidebar, ClassSidebarEntry } from "../../../types";

  // Duplicated in the is:inline fast-path script above - keep in sync.
  const OPEN_STATE_KEY = "wiki-classes-group-open";
  const HTML_CACHE_KEY = "wiki-classes-group-html-v2";

  interface Templates {
    /** A collapsible group <li> - cloned for the group and its subgroups. */
    group: HTMLElement;
    /** A link <li> inside that group - cloned for every class link. */
    link: HTMLElement;
  }

  async function buildClassesGroup(): Promise<void> {
    const topLevel = document.querySelector("#starlight__sidebar ul.top-level");
    // Already injected from the sessionStorage cache by the inline script
    if (!topLevel || topLevel.querySelector("[data-wiki-classes-group]")) {
      return;
    }
    const templates = findTemplates(topLevel);
    const data = templates ? await fetchClassSidebar() : null;
    if (!templates || !data) {
      // Can't build the group - don't leave a dead skeleton behind
      topLevel.querySelector("[data-wiki-classes-skeleton]")?.remove();
      return;
    }

    const { group, currentLink } = renderGroup(data, templates);
    cacheGroupHtml(group);
    restoreOpenState(group, currentLink);
    const skeleton = topLevel.querySelector("[data-wiki-classes-skeleton]");
    if (skeleton) skeleton.replaceWith(group);
    else topLevel.appendChild(group);
    if (currentLink) centerInSidebar(currentLink);
  }

  /** Server-rendered DOM to clone: the first collapsible group + one link. */
  function findTemplates(topLevel: Element): Templates | null {
    const group = topLevel
      .querySelector(":scope > li:not([data-wiki-classes-skeleton]) > details")
      ?.closest("li");
    const link = group?.querySelector("details > ul a[href]")?.closest("li");
    return group && link ? { group, link } : null;
  }

  async function fetchClassSidebar(): Promise<ClassSidebar | null> {
    try {
      const base = import.meta.env.BASE_URL.replace(/\/$/, "");
      const res = await fetch(`${base}/db/classSidebar.json`);
      return res.ok ? await res.json() : null;
    } catch {
      return null;
    }
  }

  /**
   * Builds the "Classes" group <li>: collapsible subgroups first, then the
   * flat stragglers, then the unresolved-hash group last - mirroring the
   * classSidebar.json shape 1:1.
   */
  function renderGroup(
    data: ClassSidebar,
    templates: Templates,
  ): { group: HTMLElement; currentLink: HTMLAnchorElement | null } {
    const currentPath = normalizePath(location.pathname);
    let currentLink: HTMLAnchorElement | null = null;

    const makeLink = ([name, href]: ClassSidebarEntry): HTMLElement => {
      const li = templates.link.cloneNode(true) as HTMLElement;
      const a = li.querySelector("a")!;
      a.setAttribute("href", `${href}/`);
      a.removeAttribute("aria-current");
      // Keep only the label span (clones may carry badges from the template)
      const span = a.querySelector("span");
      a.replaceChildren(span ?? document.createElement("span"));
      (a.firstElementChild as HTMLElement).textContent = name;
      if (normalizePath(new URL(a.href).pathname) === currentPath) {
        a.setAttribute("aria-current", "page");
        currentLink = a;
      }
      return li;
    };

    // Collapsed by default; the branch holding the current page is expanded
    // once the whole group is built.
    const makeSubgroup = (
      label: string,
      entries: ClassSidebarEntry[],
    ): HTMLElement => {
      const li = templates.group.cloneNode(true) as HTMLElement;
      li.querySelectorAll("sl-sidebar-restore").forEach((el) => el.remove());
      const details = li.querySelector("details")!;
      details.removeAttribute("open");
      const labelEl = li.querySelector("summary .group-label .large");
      if (labelEl) labelEl.textContent = label;
      const list = details.querySelector("ul")!;
      list.innerHTML = "";
      const fragment = document.createDocumentFragment();
      for (const entry of entries) fragment.appendChild(makeLink(entry));
      list.appendChild(fragment);
      return li;
    };

    const group = templates.group.cloneNode(true) as HTMLElement;
    group.setAttribute("data-wiki-classes-group", "");
    // Starlight's <sl-sidebar-restore> restores open state by group index;
    // the clone's copy would apply the template group's state, so drop it
    // and manage open state ourselves.
    group.querySelectorAll("sl-sidebar-restore").forEach((el) => el.remove());
    const label = group.querySelector("summary .group-label .large");
    if (label) label.textContent = "Classes";

    const list = group.querySelector("details")!.querySelector("ul")!;
    list.innerHTML = "";
    const fragment = document.createDocumentFragment();
    for (const g of data.groups) {
      fragment.appendChild(makeSubgroup(g.label, g.entries));
    }
    for (const entry of data.other) {
      fragment.appendChild(makeLink(entry));
    }
    if (data.hashed.length) {
      fragment.appendChild(
        makeSubgroup(`Unhashed (${data.hashed.length})`, data.hashed),
      );
    }
    list.appendChild(fragment);

    expandBranch(currentLink, group);
    return { group, currentLink };
  }

  /** Opens every <details> between a link and the group root. */
  function expandBranch(
    link: HTMLAnchorElement | null,
    root: HTMLElement,
  ): void {
    for (let el: Element | null = link; el && el !== root; el = el.parentElement) {
      if (el instanceof HTMLDetailsElement) el.open = true;
    }
  }

  /**
   * Caches the group HTML (without page-specific state) for instant injection
   * on later navigations. ~800KB, well within quota; cleared when the tab
   * closes.
   */
  function cacheGroupHtml(group: HTMLElement): void {
    try {
      const cacheable = group.cloneNode(true) as HTMLElement;
      cacheable
        .querySelectorAll("[aria-current]")
        .forEach((el) => el.removeAttribute("aria-current"));
      cacheable
        .querySelectorAll("details")
        .forEach((el) => el.removeAttribute("open"));
      sessionStorage.setItem(HTML_CACHE_KEY, cacheable.outerHTML);
    } catch {}
  }

  /**
   * Open when viewing a class page; otherwise restore the last user choice
   * (expanded by default, matching the other groups).
   */
  function restoreOpenState(
    group: HTMLElement,
    currentLink: HTMLAnchorElement | null,
  ): void {
    const details = group.querySelector("details")!;
    details.open =
      currentLink !== null ||
      sessionStorage.getItem(OPEN_STATE_KEY) !== "false";
    details.addEventListener("toggle", () => {
      try {
        sessionStorage.setItem(OPEN_STATE_KEY, String(details.open));
      } catch {}
    });
  }

  /**
   * Center the current class in the sidebar scroller (scrollIntoView would
   * also scroll the main document, so adjust the scroller directly).
   */
  function centerInSidebar(link: HTMLAnchorElement): void {
    const scroller = document.getElementById("starlight__sidebar");
    if (!scroller) return;
    scroller.scrollTop =
      link.getBoundingClientRect().top -
      scroller.getBoundingClientRect().top +
      scroller.scrollTop -
      scroller.clientHeight / 2;
  }

  function normalizePath(path: string): string {
    return path.replace(/\/$/, "");
  }

  buildClassesGroup();
</script>
