---
// Override of Starlight's PageTitle: renders "Added"/"Removed" patch pills
// under the title for classes (since/removedIn frontmatter).
import Pill from '../Pill.astro';
import CirclePlusIcon from '../icons/CirclePlusIcon.astro';
import TrashIcon from '../icons/TrashIcon.astro';

// Starlight's PAGE_TITLE_ID ('@astrojs/starlight/constants' is not a public
// export); the skip-link and TOC target the h1 through this id
const PAGE_TITLE_ID = '_top';

const { title, removedIn, since } = Astro.locals.starlightRoute.entry.data as {
	title: string;
	removedIn?: string;
	since?: string;
};

// Each patch pill links to that patch's changelog page (slug = dots → dashes)
const changelogHref = (patch: string) => `/changelog/${patch.replace(/\./g, "-")}/`;
---

<div class="page-title">
	<h1 id={PAGE_TITLE_ID}>{title}</h1>
	{
		(removedIn || since) && (
			<div class="title-pills">
				{removedIn && (
					<a class="pill-link" href={changelogHref(removedIn)}>
						<Pill
							variant="danger"
							title={`This class no longer exists in the game as of patch ${removedIn} - see the changelog`}
						>
							<TrashIcon slot="icon" size={12} strokeWidth={2.5} />
							Removed in <b>{removedIn}</b>
						</Pill>
					</a>
				)}
				{since && (
					<a class="pill-link" href={changelogHref(since)}>
						<Pill variant="success" title={`Added in patch ${since} - see the changelog`}>
							<CirclePlusIcon slot="icon" size={12} strokeWidth={2.5} />
							{since}
						</Pill>
					</a>
				)}
			</div>
		)
	}
</div>

<style>
	.page-title {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.625rem;
		margin-top: 1rem;
	}

	.title-pills {
		display: flex;
		align-items: center;
		gap: 0.375rem;
	}

	.pill-link {
		text-decoration: none;
		border-radius: 0.4rem;
		transition: filter 0.15s;
	}

	.pill-link:hover {
		text-decoration: none;
		filter: brightness(1.08);
	}

	/* Hint the pill is now interactive */
	.pill-link :global(.pill) {
		cursor: pointer;
	}

	h1 {
		margin: 0;
		font-size: var(--sl-text-h1);
		line-height: var(--sl-line-height-headings);
		font-weight: 600;
		color: var(--sl-color-white);
	}
</style>
