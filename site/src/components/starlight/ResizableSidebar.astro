---
import DefaultSidebar from "@astrojs/starlight/components/Sidebar.astro";
---

<script is:inline>
  // Run immediately to restore saved width to prevent FOUC
  try {
    const savedWidth = localStorage.getItem("starlight-sidebar-width");
    if (savedWidth) {
      document.documentElement.style.setProperty(
        "--sl-sidebar-width",
        savedWidth,
      );
    }
  } catch (e) {
    /* ignore */
  }
</script>

<DefaultSidebar />

<script is:inline>
  /**
   * Instant restore of the client-rendered "Classes" sidebar group.
   *
   * The ~5,300 class links are deliberately absent from the static sidebar
   * (see astro.config.mjs): baking them into every page made each HTML file
   * ~850KB and dominated build time. The group is built client-side once per
   * tab (script below) and its HTML is cached in sessionStorage; this inline
   * script re-injects it synchronously during HTML parsing so subsequent
   * navigations show the group without any flash or delay.
   */
  (() => {
    try {
      var cached = sessionStorage.getItem("wiki-classes-group-html");
      if (!cached) return;
      var topLevel = document.querySelector("#starlight__sidebar ul.top-level");
      if (!topLevel || topLevel.querySelector("[data-wiki-classes-group]"))
        return;
      topLevel.insertAdjacentHTML("beforeend", cached);
      var group = topLevel.querySelector("[data-wiki-classes-group]");
      var details = group.querySelector("details");
      var path = location.pathname.replace(/\/$/, "");
      var currentLink =
        group.querySelector('a[href="' + path + '/"]') ||
        group.querySelector('a[href="' + path + '"]');
      if (currentLink) currentLink.setAttribute("aria-current", "page");
      details.open =
        !!currentLink ||
        sessionStorage.getItem("wiki-classes-group-open") !== "false";
      details.addEventListener("toggle", function () {
        try {
          sessionStorage.setItem(
            "wiki-classes-group-open",
            String(details.open),
          );
        } catch (e) {}
      });
      // Center the current class in the sidebar scroller. This runs after
      // Starlight's own scroll restore (its inline script sits earlier in
      // the sidebar), so this position wins on class pages.
      var scroller = document.getElementById("starlight__sidebar");
      if (currentLink && scroller) {
        scroller.scrollTop =
          currentLink.getBoundingClientRect().top -
          scroller.getBoundingClientRect().top +
          scroller.scrollTop -
          scroller.clientHeight / 2;
      }
    } catch (e) {}
  })();
</script>

<div id="sidebar-resize-handle" class="resize-handle" aria-hidden="true">
  <div class="resize-handle-line"></div>
</div>

<script>
  /**
   * First-time build of the "Classes" sidebar group (see inline script above
   * for the fast path). Fetches /db/classIndex.json, clones existing
   * server-rendered sidebar DOM so new elements inherit Starlight's scoped
   * style classes, and caches the resulting HTML in sessionStorage for
   * synchronous injection on later navigations in this tab.
   */
  const OPEN_STATE_KEY = "wiki-classes-group-open";
  const HTML_CACHE_KEY = "wiki-classes-group-html";

  function normalizePath(path: string): string {
    return path.replace(/\/$/, "");
  }

  async function buildClassesGroup() {
    const topLevel = document.querySelector("#starlight__sidebar ul.top-level");
    // Already injected from the sessionStorage cache by the inline script
    if (!topLevel || topLevel.querySelector("[data-wiki-classes-group]")) {
      return;
    }
    // Template: the last existing collapsible group (e.g. "Reference")
    const groupTemplate = topLevel
      .querySelector(":scope > li > details")
      ?.closest("li");
    const linkTemplate = groupTemplate
      ?.querySelector("details > ul a[href]")
      ?.closest("li");
    if (!groupTemplate || !linkTemplate) return;

    let classIndex: Record<string, string>;
    try {
      const base = import.meta.env.BASE_URL.replace(/\/$/, "");
      const res = await fetch(`${base}/db/classIndex.json`);
      if (!res.ok) return;
      classIndex = await res.json();
    } catch {
      return;
    }

    const group = groupTemplate.cloneNode(true) as HTMLElement;
    group.setAttribute("data-wiki-classes-group", "");
    const details = group.querySelector("details")!;
    const label = group.querySelector("summary .group-label .large");
    if (label) label.textContent = "Classes";
    // Starlight's <sl-sidebar-restore> restores open state by group index;
    // the clone's copy would apply the template group's state, so drop it
    // and manage open state ourselves.
    group.querySelectorAll("sl-sidebar-restore").forEach((el) => el.remove());
    const list = details.querySelector("ul")!;
    list.innerHTML = "";

    const currentPath = normalizePath(location.pathname);
    let currentLink: HTMLAnchorElement | null = null;
    const fragment = document.createDocumentFragment();
    const entries = Object.entries(classIndex).sort(([a], [b]) =>
      a.localeCompare(b, "en", { sensitivity: "base" }),
    );
    for (const [name, href] of entries) {
      const li = linkTemplate.cloneNode(true) as HTMLElement;
      const a = li.querySelector("a")!;
      a.setAttribute("href", `${href}/`);
      a.removeAttribute("aria-current");
      // Keep only the label span (clones may carry badges from the template)
      const span = a.querySelector("span");
      a.replaceChildren(span ?? document.createElement("span"));
      (a.firstElementChild as HTMLElement).textContent = name;
      if (normalizePath(new URL(a.href).pathname) === currentPath) {
        a.setAttribute("aria-current", "page");
        currentLink = a;
      }
      fragment.appendChild(li);
    }
    list.appendChild(fragment);

    // Cache the group HTML (without page-specific state) for instant
    // injection on later navigations. ~800KB, well within quota; cleared
    // when the tab closes.
    try {
      const cacheable = group.cloneNode(true) as HTMLElement;
      cacheable
        .querySelectorAll("[aria-current]")
        .forEach((el) => el.removeAttribute("aria-current"));
      cacheable.querySelector("details")?.removeAttribute("open");
      sessionStorage.setItem(HTML_CACHE_KEY, cacheable.outerHTML);
    } catch {}

    // Open when viewing a class page; otherwise restore the last user choice
    // (expanded by default, matching the other groups).
    const storedOpen = sessionStorage.getItem(OPEN_STATE_KEY);
    details.open = currentLink !== null || storedOpen !== "false";
    details.addEventListener("toggle", () => {
      try {
        sessionStorage.setItem(OPEN_STATE_KEY, String(details.open));
      } catch {}
    });

    topLevel.appendChild(group);

    // Center the current class in the sidebar scroller (scrollIntoView would
    // also scroll the main document, so adjust the scroller directly).
    const scroller = document.getElementById("starlight__sidebar");
    if (currentLink && scroller) {
      const linkTop =
        currentLink.getBoundingClientRect().top -
        scroller.getBoundingClientRect().top +
        scroller.scrollTop;
      scroller.scrollTop = linkTop - scroller.clientHeight / 2;
    }
  }

  buildClassesGroup();
</script>

<script>
  class SidebarResizer {
    handle: HTMLElement;
    isResizing: boolean = false;
    startX: number = 0;
    startWidth: number = 0;

    constructor(handle: HTMLElement) {
      this.handle = handle;

      // Bind events
      this.handle.addEventListener("mousedown", this.startResize.bind(this));
      document.addEventListener("mousemove", this.resize.bind(this));
      document.addEventListener("mouseup", this.stopResize.bind(this));

      // Reset on double click
      this.handle.addEventListener("dblclick", () => {
        document.documentElement.style.removeProperty("--sl-sidebar-width");
        localStorage.removeItem("starlight-sidebar-width");
      });
    }

    startResize(e: MouseEvent) {
      this.isResizing = true;
      this.startX = e.clientX;
      this.handle.classList.add("resizing");

      // Calculate current width in pixels
      const rootStyle = getComputedStyle(document.documentElement);
      const sidebarWidthVar = rootStyle
        .getPropertyValue("--sl-sidebar-width")
        .trim();

      if (sidebarWidthVar.endsWith("px")) {
        this.startWidth = parseFloat(sidebarWidthVar);
      } else if (sidebarWidthVar.endsWith("rem")) {
        const rootFontSize = parseFloat(rootStyle.fontSize);
        this.startWidth = parseFloat(sidebarWidthVar) * (rootFontSize || 16);
      } else {
        // Default fallback if something is weird
        this.startWidth = 288;
      }

      // Prevent text selection during resize
      document.body.style.userSelect = "none";
      document.body.style.cursor = "col-resize";
    }

    resize(e: MouseEvent) {
      if (!this.isResizing) return;

      const delta = e.clientX - this.startX;
      const newWidth = this.startWidth + delta;

      // Min/Max constraints (200px to 50vw)
      const maxW = window.innerWidth * 0.5;
      if (newWidth < 200 || newWidth > maxW) return;

      const widthStr = `${newWidth}px`;
      document.documentElement.style.setProperty(
        "--sl-sidebar-width",
        widthStr,
      );
    }

    stopResize() {
      if (!this.isResizing) return;

      this.isResizing = false;
      this.handle.classList.remove("resizing");
      document.body.style.userSelect = "";
      document.body.style.cursor = "";

      // Save preference
      const currentWidth =
        document.documentElement.style.getPropertyValue("--sl-sidebar-width");
      if (currentWidth) {
        localStorage.setItem("starlight-sidebar-width", currentWidth);
      }
    }
  }

  // Initialize
  const handle = document.getElementById("sidebar-resize-handle");
  if (handle) {
    new SidebarResizer(handle);
  }
</script>

<style>
  .resize-handle {
    position: fixed;
    top: var(--sl-nav-height, 3.5rem);
    bottom: 0;
    left: var(--sl-sidebar-width);
    width: 12px;
    margin-left: -6px; /* Center on the line */
    cursor: col-resize;
    z-index: 2000; /* Ensure it's above most things */
    display: none; /* Hidden by default (mobile) */
    align-items: center;
    justify-content: center;
    touch-action: none;
  }

  /* Only show on desktop */
  @media (min-width: 50rem) {
    /* 800px - Starlight mobile breakpoint */
    .resize-handle {
      display: flex;
    }
  }

  .resize-handle-line {
    width: 2px;
    height: 100%;
    background-color: transparent;
    transition: background-color 0.2s;
  }

  .resize-handle:hover .resize-handle-line,
  .resize-handle.resizing .resize-handle-line {
    background-color: var(
      --sl-color-accent,
      var(--color-brand-primary, #7c3aed)
    );
  }
</style>
