---
/**
 * Starlight `Sidebar` override (see astro.config.mjs -> components.Sidebar).
 * Renders the default sidebar plus our two additions:
 *
 * - ResizeHandle: drag-to-resize with persisted width. Placed before the
 *   sidebar so its width restore runs pre-paint (the handle is fixed-position,
 *   so DOM order doesn't matter visually).
 * - ClassesGroup: the client-built "Classes" group. Placed after the sidebar
 *   because its scripts attach to the rendered sidebar DOM.
 */
import DefaultSidebar from "@astrojs/starlight/components/Sidebar.astro";
import ResizeHandle from "./sidebar/ResizeHandle.astro";
import ClassesGroup from "./sidebar/ClassesGroup.astro";
---

<ResizeHandle />
<DefaultSidebar />
<ClassesGroup />
