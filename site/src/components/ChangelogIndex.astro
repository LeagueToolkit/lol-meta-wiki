---
import fs from "node:fs";
import { root } from "astro:config/server";
import type { ChangelogIndexEntry } from "../types";

// Read the changelog index at build time (server-side only). Lives in
// site/db-data/changelog/ (outside public/), same as the per-patch JSON.
const dataUrl = new URL("./db-data/changelog/index.json", root);
const { patches } = JSON.parse(fs.readFileSync(dataUrl, "utf8")) as {
  patches: ChangelogIndexEntry[];
};

// A relative bar scale so churny patches stand out at a glance
const maxTotal = Math.max(
  1,
  ...patches.map((p) => p.counts.added + p.counts.changed + p.counts.removed)
);
---

<div class="changelog-index" data-pagefind-ignore>
  <div class="cl-table">
    <div class="cl-row cl-head" aria-hidden="true">
      <span class="cl-patch">Patch</span>
      <span class="cl-num">New</span>
      <span class="cl-num">Changed</span>
      <span class="cl-num">Removed</span>
      <span class="cl-bar-head">Churn</span>
    </div>
    {
      patches.map((p) => {
        const total = p.counts.added + p.counts.changed + p.counts.removed;
        const pct = (n: number) => `${(n / maxTotal) * 100}%`;
        const label =
          `Patch ${p.patch}` +
          (p.builds.length > 1 ? `, ${p.builds.length} builds` : "") +
          `: ${p.counts.added} new, ${p.counts.changed} changed, ` +
          `${p.counts.removed} removed`;
        return (
          <a class="cl-row" href={`/changelog/${p.slug}/`} aria-label={label}>
            <span class="cl-patch">
              {p.patch}
              {p.builds.length > 1 && (
                <span class="cl-builds">{p.builds.length} builds</span>
              )}
            </span>
            <span class="cl-num cl-added" aria-hidden="true">{p.counts.added || "-"}</span>
            <span class="cl-num cl-changed" aria-hidden="true">{p.counts.changed || "-"}</span>
            <span class="cl-num cl-removed" aria-hidden="true">{p.counts.removed || "-"}</span>
            <span class="cl-bar" aria-hidden="true" title={`${total} classes changed`}>
              <span class="seg seg-added" style={`width:${pct(p.counts.added)}`} />
              <span class="seg seg-changed" style={`width:${pct(p.counts.changed)}`} />
              <span class="seg seg-removed" style={`width:${pct(p.counts.removed)}`} />
            </span>
          </a>
        );
      })
    }
  </div>
</div>

<style>
  .changelog-index {
    margin-top: 1rem;
  }

  .cl-table {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--sl-color-gray-5, #e5e7eb);
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .cl-row {
    display: grid;
    grid-template-columns: minmax(6rem, 1.3fr) 4rem 5rem 5rem minmax(6rem, 2fr);
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.85rem;
    border-bottom: 1px solid var(--sl-color-gray-6, #f3f4f6);
    text-decoration: none;
    color: inherit;
  }
  a.cl-row {
    transition: background 0.12s;
  }
  a.cl-row:hover {
    background: var(--sl-color-gray-6, #f9fafb);
    text-decoration: none;
  }
  .cl-row:last-child {
    border-bottom: none;
  }

  .cl-head {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--sl-color-gray-3, #6b7280);
    background: var(--sl-color-gray-6, #f9fafb);
  }

  .cl-patch {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    font-weight: 600;
    color: var(--sl-color-white, #1f2937);
  }
  .cl-head .cl-patch {
    font-weight: 600;
    color: var(--sl-color-gray-3, #6b7280);
  }
  .cl-builds {
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: none;
    letter-spacing: 0;
    color: var(--sl-color-gray-3, #9ca3af);
  }

  .cl-num {
    text-align: right;
    font-variant-numeric: tabular-nums;
    font-size: 0.85rem;
  }
  .cl-head .cl-num {
    text-align: right;
  }
  .cl-added {
    color: var(--sl-color-green-high, #15803d);
  }
  .cl-changed {
    color: var(--sl-color-orange-high, #c2410c);
  }
  .cl-removed {
    color: var(--sl-color-red-high, #b91c1c);
  }

  .cl-bar {
    display: flex;
    height: 0.55rem;
    border-radius: 999px;
    overflow: hidden;
    background: var(--sl-color-gray-6, #f3f4f6);
  }
  .cl-bar-head {
    font-size: 0.7rem;
  }
  .seg {
    height: 100%;
  }
  .seg-added {
    background: var(--sl-color-green, #22c55e);
  }
  .seg-changed {
    background: var(--sl-color-orange, #f97316);
  }
  .seg-removed {
    background: var(--sl-color-red, #ef4444);
  }

  @media (max-width: 640px) {
    .cl-row {
      grid-template-columns: minmax(5rem, 1fr) 3rem 3rem 3rem;
    }
    .cl-bar,
    .cl-bar-head {
      display: none;
    }
  }
</style>
