---
// Sticky summary line for a patch page. Each count doubles as a jump-link to
// its section (#sec-added / #sec-changed / #sec-removed) and stays reachable as
// a jump-nav on tall patches (the biggest are 200+ entries with no TOC).
interface Props {
  added: number;
  changed: number;
  removed: number;
}

const { added, changed, removed } = Astro.props;
const total = added + changed + removed;
---

<p class="summary">
  {added > 0 && (
    <a class="stat stat-added" href="#sec-added">
      <b>{added}</b> new
    </a>
  )}
  {changed > 0 && (
    <a class="stat stat-changed" href="#sec-changed">
      <b>{changed}</b> changed
    </a>
  )}
  {removed > 0 && (
    <a class="stat stat-removed" href="#sec-removed">
      <b>{removed}</b> removed
    </a>
  )}
  <span class="stat-classes">{total === 1 ? "class" : "classes"}</span>
</p>

<style>
  /* Sticky so the counts stay reachable as a jump-nav on tall patches */
  .summary {
    position: sticky;
    top: var(--sl-nav-height, 3.75rem);
    z-index: 2;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 1.5rem;
    padding: 0.5rem 0;
    background: var(--sl-color-bg, #fff);
    border-bottom: 1px solid var(--sl-color-gray-5, #e5e7eb);
    font-size: 0.95rem;
  }

  .stat {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.2rem 0.6rem;
    border-radius: 0.4rem;
    border: 1px solid transparent;
    font-size: 0.85rem;
  }
  a.stat {
    text-decoration: none;
    transition: filter 0.15s;
  }
  a.stat:hover {
    text-decoration: none;
    filter: brightness(1.12);
  }
  .stat b {
    font-weight: 700;
  }
  .stat-added {
    color: var(--sl-color-green-high, #15803d);
    background: color-mix(in srgb, var(--sl-color-green, #22c55e) 12%, transparent);
    border-color: color-mix(in srgb, var(--sl-color-green, #22c55e) 30%, transparent);
  }
  .stat-changed {
    color: var(--sl-color-orange-high, #c2410c);
    background: color-mix(in srgb, var(--sl-color-orange, #f97316) 12%, transparent);
    border-color: color-mix(in srgb, var(--sl-color-orange, #f97316) 30%, transparent);
  }
  .stat-removed {
    color: var(--sl-color-red-high, #b91c1c);
    background: color-mix(in srgb, var(--sl-color-red, #ef4444) 12%, transparent);
    border-color: color-mix(in srgb, var(--sl-color-red, #ef4444) 30%, transparent);
  }
  .stat-classes {
    color: var(--sl-color-gray-3, #6b7280);
    font-size: 0.85rem;
  }
</style>
