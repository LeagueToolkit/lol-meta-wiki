---
import fs from "node:fs";
import { root } from "astro:config/server";
import { classIndex } from "../utils/classIndex";
import InheritanceTree from "./InheritanceTree.astro";
import PropertiesSection from "./PropertiesSection.astro";
import ClassDocumentation from "./ClassDocumentation.astro";
// import InheritanceDiagram from "./InheritanceDiagram.astro";
// import MermaidLoader from "./MermaidLoader.astro";
// import { generateInheritanceDiagram } from "../utils/mermaidGenerator";

// Props: { file: string } e.g. "/db/classes/BuffSpell.a1b2c3d4e5f6.json"
const { file } = Astro.props;

// Read the class data at build time (server-side only). The stable
// "/db/classes/<file>.json" identifier maps to site/db-data/classes/, which
// lives outside public/ so the 5k+ JSON files aren't copied into dist on
// every build. Paths are anchored to project dirs from astro:config/server,
// not import.meta.url — after bundling this module lives in dist/.prerender/.
const dataUrl = new URL(
  `./db-data/classes/${file.replace(/^\/db\/classes\//, "")}`,
  root
);
const data = JSON.parse(fs.readFileSync(dataUrl, "utf8"));

// Whether a hand-written docs file exists for this class decides if the
// documentation buttons link to GitHub's edit flow or its create-file flow
const docsFileUrl = new URL(`../db/docs/${data.name}.yaml`, root);
const docExists = fs.existsSync(docsFileUrl);

// For Mermaid diagram (future use):
// const mermaidDiagram = generateInheritanceDiagram(data, classIndex);
---

<InheritanceTree
  currentClass={data.name}
  ancestorLevels={data.ancestorLevels}
  descendantTree={data.descendantTree}
  classIndex={classIndex}
/>

<ClassDocumentation name={data.name} docs={data.docs} docExists={docExists} />

{
  data.properties.length > 0 && (
    <PropertiesSection
      properties={data.properties}
      classIndex={classIndex}
      name={data.name}
      docExists={docExists}
    />
  )
}

