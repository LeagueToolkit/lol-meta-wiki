# EditorConfig - https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown: trailing whitespace can be a hard line break, so leave it alone
[*.md]
trim_trailing_whitespace = false
